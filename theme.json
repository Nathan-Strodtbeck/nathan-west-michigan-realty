{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "custom": true,
      "customDuotone": false,
      "customGradient": true,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "duotone": [],
      "gradients": [
        {
          "slug": "navy-dark",
          "gradient": "linear-gradient(135deg, #0B1F3A 0%, #162d50 100%)",
          "name": "Navy Dark"
        },
        {
          "slug": "gold-fade",
          "gradient": "linear-gradient(135deg, #C8A96B 0%, #b8965a 100%)",
          "name": "Gold Fade"
        }
      ],
      "palette": [
        {
          "slug": "navy",
          "color": "#0B1F3A",
          "name": "Navy"
        },
        {
          "slug": "navy-dark",
          "color": "#07152a",
          "name": "Navy Dark"
        },
        {
          "slug": "white",
          "color": "#FFFFFF",
          "name": "White"
        },
        {
          "slug": "light-gray",
          "color": "#F5F7FA",
          "name": "Light Gray"
        },
        {
          "slug": "mid-gray",
          "color": "#E2E8F0",
          "name": "Mid Gray"
        },
        {
          "slug": "dark-text",
          "color": "#111827",
          "name": "Dark Text"
        },
        {
          "slug": "body-text",
          "color": "#374151",
          "name": "Body Text"
        },
        {
          "slug": "gold",
          "color": "#C8A96B",
          "name": "Gold Accent"
        },
        {
          "slug": "gold-dark",
          "color": "#b8965a",
          "name": "Gold Dark"
        }
      ]
    },
    "custom": {
      "spacing": {
        "small": "clamp(1.5rem, 4vw, 2rem)",
        "medium": "clamp(3rem, 6vw, 5rem)",
        "large": "clamp(5rem, 10vw, 8rem)"
      },
      "lineHeight": {
        "tiny": "1.15",
        "small": "1.3",
        "medium": "1.6",
        "large": "1.8"
      }
    },
    "layout": {
      "contentSize": "840px",
      "wideSize": "1200px"
    },
    "spacing": {
      "blockGap": true,
      "customSpacingSize": true,
      "defaultSpacingSizes": false,
      "margin": true,
      "padding": true,
      "spacingSizes": [
        { "name": "1", "slug": "10", "size": "0.25rem" },
        { "name": "2", "slug": "20", "size": "0.5rem" },
        { "name": "3", "slug": "30", "size": "0.75rem" },
        { "name": "4", "slug": "40", "size": "1rem" },
        { "name": "5", "slug": "50", "size": "1.5rem" },
        { "name": "6", "slug": "60", "size": "2rem" },
        { "name": "7", "slug": "70", "size": "3rem" },
        { "name": "8", "slug": "80", "size": "4rem" },
        { "name": "9", "slug": "90", "size": "5rem" },
        { "name": "10", "slug": "100", "size": "8rem" }
      ]
    },
    "typography": {
      "customFontSize": true,
      "dropCap": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "'Montserrat', 'Helvetica Neue', Arial, sans-serif",
          "slug": "montserrat",
          "name": "Montserrat"
        },
        {
          "fontFamily": "'Inter', 'Helvetica Neue', Arial, sans-serif",
          "slug": "inter",
          "name": "Inter"
        },
        {
          "fontFamily": "Georgia, 'Times New Roman', serif",
          "slug": "serif",
          "name": "Serif"
        }
      ],
      "fontSizes": [
        { "name": "X-Small", "slug": "xs", "size": "0.75rem" },
        { "name": "Small", "slug": "sm", "size": "0.875rem" },
        { "name": "Base", "slug": "base", "size": "1rem" },
        { "name": "Medium", "slug": "md", "size": "1.125rem" },
        { "name": "Large", "slug": "lg", "size": "1.25rem" },
        { "name": "X-Large", "slug": "xl", "size": "clamp(1.5rem, 3vw, 2rem)" },
        { "name": "2X-Large", "slug": "2xl", "size": "clamp(1.875rem, 4vw, 2.5rem)" },
        { "name": "3X-Large", "slug": "3xl", "size": "clamp(2.25rem, 5vw, 3.5rem)" },
        { "name": "4X-Large", "slug": "4xl", "size": "clamp(2.75rem, 6vw, 4.5rem)" }
      ],
      "lineHeight": true
    }
  },
  "styles": {
    "blocks": {
      "core/button": {
        "css": ".wp-block-button__link { font-family: var(--wp--preset--font-family--montserrat); font-weight: 600; letter-spacing: 0.03em; transition: all 0.2s ease; } .wp-block-button__link:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,0.18); }",
        "variations": {
          "outline": {
            "border": {
              "radius": "4px"
            }
          }
        }
      },
      "core/code": {
        "color": {
          "background": "#F5F7FA",
          "text": "#111827"
        },
        "typography": {
          "fontFamily": "monospace",
          "fontSize": "0.875rem"
        }
      },
      "core/heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--montserrat)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        },
        "color": {
          "text": "#111827"
        }
      },
      "core/navigation": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--sm)",
          "fontWeight": "500",
          "letterSpacing": "0.02em"
        }
      },
      "core/post-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--montserrat)",
          "fontWeight": "700"
        }
      },
      "core/pullquote": {
        "border": {
          "color": "#C8A96B",
          "style": "solid",
          "width": "3px 0"
        },
        "color": {
          "text": "#0B1F3A"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--montserrat)",
          "fontSize": "var(--wp--preset--font-size--lg)",
          "fontStyle": "italic"
        }
      },
      "core/quote": {
        "border": {
          "color": "#C8A96B",
          "style": "solid",
          "width": "0 0 0 4px"
        },
        "color": {
          "text": "#374151"
        },
        "spacing": {
          "padding": {
            "left": "1.5rem"
          }
        }
      },
      "core/separator": {
        "color": {
          "text": "#E2E8F0"
        }
      }
    },
    "color": {
      "background": "#FFFFFF",
      "text": "#374151"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "4px"
        },
        "color": {
          "background": "#0B1F3A",
          "text": "#FFFFFF"
        },
        ":hover": {
          "color": {
            "background": "#162d50"
          }
        },
        ":focus": {
          "outline": {
            "color": "#C8A96B",
            "offset": "2px",
            "style": "solid",
            "width": "2px"
          }
        },
        "spacing": {
          "padding": {
            "top": "0.875rem",
            "bottom": "0.875rem",
            "left": "1.75rem",
            "right": "1.75rem"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--montserrat)",
          "fontSize": "var(--wp--preset--font-size--sm)",
          "fontWeight": "600",
          "letterSpacing": "0.04em",
          "textDecoration": "none"
        }
      },
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--montserrat)",
          "fontSize": "var(--wp--preset--font-size--4xl)",
          "fontWeight": "700",
          "lineHeight": "1.15"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--montserrat)",
          "fontSize": "var(--wp--preset--font-size--3xl)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--montserrat)",
          "fontSize": "var(--wp--preset--font-size--2xl)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--montserrat)",
          "fontSize": "var(--wp--preset--font-size--xl)",
          "fontWeight": "600",
          "lineHeight": "1.4"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--montserrat)",
          "fontSize": "var(--wp--preset--font-size--lg)",
          "fontWeight": "600"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--montserrat)",
          "fontSize": "var(--wp--preset--font-size--md)",
          "fontWeight": "600"
        }
      },
      "link": {
        "color": {
          "text": "#0B1F3A"
        },
        ":hover": {
          "color": {
            "text": "#C8A96B"
          },
          "typography": {
            "textDecoration": "none"
          }
        },
        "typography": {
          "textDecoration": "underline"
        }
      }
    },
    "spacing": {
      "blockGap": "1.5rem"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "fontWeight": "400",
      "lineHeight": "1.7"
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ],
  "customTemplates": [
    {
      "name": "page-buy",
      "postTypes": ["page"],
      "title": "Buy Page"
    },
    {
      "name": "page-sell",
      "postTypes": ["page"],
      "title": "Sell Page"
    },
    {
      "name": "page-va-loans",
      "postTypes": ["page"],
      "title": "VA Loans Page"
    },
    {
      "name": "page-first-time-buyers",
      "postTypes": ["page"],
      "title": "First-Time Buyers Page"
    },
    {
      "name": "page-about",
      "postTypes": ["page"],
      "title": "About Page"
    },
    {
      "name": "page-contact",
      "postTypes": ["page"],
      "title": "Contact Page"
    },
    {
      "name": "page-home-valuation",
      "postTypes": ["page"],
      "title": "Home Valuation Page"
    },
    {
      "name": "page-featured-listings",
      "postTypes": ["page"],
      "title": "Featured Listings Page"
    },
    {
      "name": "page-area-landing",
      "postTypes": ["page", "area_guide"],
      "title": "City / Area Landing Page"
    },
    {
      "name": "page-neighborhood-guide",
      "postTypes": ["page", "area_guide"],
      "title": "Neighborhood Guide"
    },
    {
      "name": "page-privacy",
      "postTypes": ["page"],
      "title": "Privacy Policy Page"
    },
    {
      "name": "page-terms",
      "postTypes": ["page"],
      "title": "Terms Page"
    },
    {
      "name": "blank",
      "postTypes": ["page"],
      "title": "Blank (No Header/Footer)"
    }
  ]
}
